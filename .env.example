# ========================================================
# AI PROJECT ANALYZER & CODEBASE EVALUATION PLATFORM
# Environment Configuration Template
# ========================================================

# 1. CORE AI ENGINE (Mandatory for all Analysis features)
# Get your API key from Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. GITHUB OAUTH (For logging in via GitHub & pulling repos)
# Register a GitHub OAuth App at Developer Settings
GITHUB_CLIENT_ID="your_github_client_id_here"
GITHUB_CLIENT_SECRET="your_github_client_secret_here"

# Set this to your Vercel deployment URL (e.g., https://your-project.vercel.app) to fix OAuth redirect mismatches
# For localhost development, set it to http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 3. GOOGLE OAUTH (For logging in via Google)
# Generate from Google Cloud Console -> Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here"

# 4. SUPABASE (For user data persistence & session management)
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="your_supabase_project_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
